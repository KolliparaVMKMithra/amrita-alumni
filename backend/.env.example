# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/alumni_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Firebase
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# Admin
ADMIN_USERNAME=alumni_admin
ADMIN_PASSWORD_HASH=$2b$12$... (generate with scripts/generate_admin_hash.py)
ADMIN_JWT_SECRET=your-64-character-random-string-here-change-this-in-production-now

# CORS
CORS_ORIGIN=http://localhost:3000

# SMTP (Gmail App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM_NAME=Amrita University Alumni Portal
